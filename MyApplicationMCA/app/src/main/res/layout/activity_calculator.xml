<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:weightSum="100"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".CalculatorActivity">

    <!-- Display Screen -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="90">
    <TextView
        android:id="@+id/tvResult"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text="0"
        android:textSize="35sp"
        android:gravity="end|center_vertical"
        android:background="#FFFFFF"
        android:textColor="#000"
        android:padding="16dp"
        android:layout_marginBottom="20dp"/>

    </LinearLayout>


    <!-- Row 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button android:text="7" style="@style/btnStyle"/>
        <Button android:text="8" style="@style/btnStyle"/>
        <Button android:text="9" style="@style/btnStyle"/>
        <Button android:text="/" style="@style/btnStyleOp"/>
    </LinearLayout>

    <!-- Row 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button android:text="4" style="@style/btnStyle"/>
        <Button android:text="5" style="@style/btnStyle"/>
        <Button android:text="6" style="@style/btnStyle"/>
        <Button android:text="*" style="@style/btnStyleOp"/>
    </LinearLayout>

    <!-- Row 3 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button android:text="1" style="@style/btnStyle"/>
        <Button android:text="2" style="@style/btnStyle"/>
        <Button android:text="3" style="@style/btnStyle"/>
        <Button android:text="-" style="@style/btnStyleOp"/>
    </LinearLayout>

    <!-- Row 4 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button android:text="0" style="@style/btnStyle"/>
        <Button android:text="%" style="@style/btnStyleOp"/>
        <Button android:text="C" style="@style/btnStyleClear"/>
        <Button android:text="+" style="@style/btnStyleOp"/>
    </LinearLayout>

    <!-- Equal Button -->
    <Button
        android:id="@+id/btnEqual"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="="
        android:textSize="22sp"
        android:background="#4CAF50"
        android:textColor="#FFFFFF"
        android:layout_marginTop="10dp"/>


</LinearLayout>