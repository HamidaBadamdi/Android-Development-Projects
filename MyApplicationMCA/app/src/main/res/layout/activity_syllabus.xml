<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5FFFFFF"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="10dp"
    android:weightSum="100">

    <!-- Profile Section -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="30"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/imgProfile"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:scaleType="centerCrop"
            android:src="@drawable/profile_image" />

        <TextView
            android:id="@+id/txtInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="Hamida Badamdi\nMCA - Android Project"
            android:textColor="#555"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Buttons Section -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="70"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/unit1Layout"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_margin="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="10dp"
            android:clickable="true"
            android:background="@drawable/rounded_layout"
            android:focusable="true">

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="1"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:background="@drawable/circle_bg"/>

            <!-- Unit Text -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:text="Basics of Android"
                android:textColor="#282727"
                android:textStyle="bold"
                android:textSize="18sp"
                 />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/unit2Layout"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_margin="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="10dp"
            android:clickable="true"
            android:background="@drawable/rounded_layout"
            android:focusable="true">

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="2"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:background="@drawable/circle_bg"/>

            <!-- Unit Text -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Android Layouts, Widgets"
                android:textSize="18sp"
                android:textColor="#282727"
                android:textStyle="bold"
                android:layout_marginStart="15dp"/>
        </LinearLayout>
        <LinearLayout
            android:id="@+id/unit3Layout"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_margin="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="10dp"
            android:clickable="true"
            android:background="@drawable/rounded_layout"
            android:focusable="true">

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="3"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:background="@drawable/circle_bg"/>

            <!-- Unit Text -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Animation, API, Services"
                android:textSize="18sp"
                android:textColor="#282727"
                android:textStyle="bold"
                android:layout_marginStart="15dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/unit4Layout"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_margin="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="10dp"
            android:clickable="true"
            android:background="@drawable/rounded_layout"
            android:focusable="true">

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="4"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:background="@drawable/circle_bg"/>

            <!-- Unit Text -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DialogBox, VideoView and Storage"
                android:textSize="18sp"
                android:textColor="#282727"
                android:textStyle="bold"
                android:layout_marginStart="15dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/unit5Layout"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_margin="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="10dp"
            android:clickable="true"
            android:background="@drawable/rounded_layout"
            android:focusable="true">

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="5"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:background="@drawable/circle_bg"/>

            <!-- Unit Text -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Location and Sensor API, JSON "
                android:textSize="18sp"
                android:textColor="#282727"
                android:textStyle="bold"
                android:layout_marginStart="15dp"/>
        </LinearLayout>





    </LinearLayout>

</LinearLayout>
